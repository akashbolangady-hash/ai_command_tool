def parse_command(text):
    response=llm.create_chat_completion(messages=[{
        "role":"system",
        "content":f" User's query:{text}. Your role is to infer and analyse the user's response here and simply write/pick a tool to use and pick carefully simply. Reply in the tool names only such as 'search','weather','time' only and only if it is relevant to the user's context else reply with 'None' if you can infer there is no function to call upon"
    }])
    message=response["choices"][0]["message"]
    print(message["content"])
    if message["content"] == "weather":
        return "weather"
    elif message["content"]=="time":
        return "time"
    elif message["content"]=="search":
        return "search"
    else:
        return "None"

