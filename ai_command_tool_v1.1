def summarize_article(text, num_sentences=5):
    # Load the text into the pure-Python parser
    parser = PlaintextParser.from_string(text, Tokenizer("english"))
    
    # Use TextRank (a pure mathematical algorithm based on Google's PageRank)
    summarizer = TextRankSummarizer()
    
    # Extract the top sentences
    summary_sentences = summarizer(parser.document, num_sentences)
    
    # Join them back into a clean string paragraph
    return " ".join([str(sentence) for sentence in summary_sentences])


def tool_call(choices):
